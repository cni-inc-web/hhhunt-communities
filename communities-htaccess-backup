# Turn off directory browsing
Options -Indexes

# Use INTERNAL path for 404 template (prevents 302)
ErrorDocument 404 /404.html

DirectoryIndex index.html index.php community-overview.html
AddType image/avif .avif

######################
RewriteEngine On

# Canonical: HTTPS + www
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\.
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)\.?$ [NC]
RewriteCond %{REQUEST_URI} !^/[0-9]+\..+\.cpaneldcv$
RewriteCond %{REQUEST_URI} !^/\.well-known/pki-validation/[A-F0-9]{32}\.txt(?:\ Comodo\ DCV)?$
RewriteRule .* https://www.hhhuntcommunities.com%{REQUEST_URI} [R=301,L]

# Remove index.html from URLs
RewriteRule ^index\.html$ / [R=301,L]
RewriteRule ^(.*)/index\.html$ /$1/ [R=301,L]

# Ensure direct requests to /404.html return 404 (not 200)
RewriteCond %{THE_REQUEST} \s/+404\.html [NC]
RewriteRule ^404\.html$ - [R=404,L]

